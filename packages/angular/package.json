{
  "name": "@galaxy-ui/angular",
  "version": "0.0.1",
  "description": "Galaxy UI components for Angular with Radix NG + Tailwind CSS",
  "type": "module",
  "main": "./dist/fesm2022/galaxy-ui-angular.mjs",
  "module": "./dist/fesm2022/galaxy-ui-angular.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "@galaxy-ui/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/galaxy-ui-angular.mjs",
      "default": "./dist/fesm2022/galaxy-ui-angular.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "angular",
    "components",
    "ui",
    "@radix-ng/primitives",
    "tailwind",
    "tailwindcss",
    "accessible",
    "galaxy-ui"
  ],
  "author": {
    "name": "Bùi Trọng Hiếu (kevinbui)",
    "email": "kevinbui210191@gmail.com",
    "url": "https://github.com/buikevin"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buikevin/galaxy-design",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/buikevin/galaxy-design/issues"
  },
  "homepage": "https://github.com/buikevin/galaxy-design#readme",
  "peerDependencies": {
    "@angular/common": "~20.3.0",
    "@angular/core": "~20.3.0"
  },
  "dependencies": {
    "@radix-ng/primitives": "^0.43.0",
    "angular-split": "^20.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "lucide-angular": "^0.548.0",
    "ngx-echarts": "^18.0.0",
    "echarts": "^5.5.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~20.3.0",
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/compiler-cli": "~20.3.0",
    "@angular/platform-browser-dynamic": "~20.3.0",
    "@types/jasmine": "^5.1.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "jasmine-core": "^5.0.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "~20.3.0",
    "typescript": "^5.3.0",
    "zone.js": "^0.15.0"
  },
  "scripts": {
    "build": "ng build galaxy-ui-angular",
    "smoke:import": "node scripts/smoke-import.mjs",
    "verify": "npm run build && npm run smoke:import && npm pack --dry-run",
    "lint": "ng lint",
    "test": "ng test",
    "test:headless": "ng test --browsers=ChromeHeadlessCI --watch=false"
  }
}
