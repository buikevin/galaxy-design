{
  "name": "@galaxy-ui/vue",
  "version": "0.0.1",
  "description": "Galaxy UI components for Vue 3 with Radix Vue + Tailwind CSS",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@galaxy-ui/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "radix-vue",
    "tailwind",
    "tailwindcss",
    "accessible",
    "galaxy-ui"
  ],
  "author": {
    "name": "Bùi Trọng Hiếu (kevinbui)",
    "email": "kevinbui210191@gmail.com",
    "url": "https://github.com/buikevin"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buikevin/galaxy-design",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/buikevin/galaxy-design/issues"
  },
  "homepage": "https://github.com/buikevin/galaxy-design#readme",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "radix-vue": "^1.9.0",
    "@vueuse/core": "^10.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "lucide-vue-next": "^0.460.0",
    "vue-sonner": "^1.3.2",
    "vue-echarts": "^7.0.3",
    "echarts": "^5.5.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/vue": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^23.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.0"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "smoke:import": "node scripts/smoke-import.mjs",
    "verify": "npm run build && npm run smoke:import && npm pack --dry-run",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts ",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts ",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  }
}
